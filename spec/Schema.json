{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "packet": {
      "type": "object",
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "allOf": [
              {
                "properties": {
                  "name": { "type": "string" },
                  "type": {
                    "type": "string",
                    "enum": [
                      "int8", "uint8", "int16", "uint16",
                      "int32", "uint32", "int64", "uint64",
                      "float", "double", "bitfield"
                    ]
                  }
                },
                "required": ["name", "type"]
              },
              {
                "if": {
                  "properties": { "type": { "const": "bitfield" } },
                  "required": ["type"]
                },
                "then": {
                  "properties": {
                    "name": { "type": "string" },
                    "type": { "const": "bitfield" },
                    "bits": {
                      "type": "array",
                      "items": { "type": "string" },
                      "minItems": 1,
                      "maxItems": 32
                    }
                  },
                  "required": ["bits"],
                  "additionalProperties": false
                },
                "else": {
                  "properties": {
                    "name": { "type": "string" },
                    "type": { "type": "string" },
                    "mult": {
                      "type": "number",
                      "description": "Multiplier to convert the raw value to a physical quantity (value x mult). Omitted when it would be 1."
                    },
                    "unit": {
                      "type": "string",
                      "description": "Physical unit of the value after applying mult. Omitted when the value has no unit, e.g. a counter."
                    }
                  },
                  "additionalProperties": false
                }
              }
            ]
          }
        }
      },
      "required": ["fields"],
      "additionalProperties": false
    }
  },
  "required": ["packet"],
  "additionalProperties": false
}